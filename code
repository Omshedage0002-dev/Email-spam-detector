import re
import pandas as pd
from sklearn.model_selection import train_test_split
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.naive_bayes import MultinomialNB
from sklearn.metrics import classification_report

def clean_text(text):
    text = text.lower()
    text = re.sub(r"<[^>]+>", " ", text)
    text = re.sub(r"[^a-z\s]", "", text)
    return re.sub(r"\s+", " ", text).strip()

def predict(model, vectorizer, email_text):
    vec = vectorizer.transform([clean_text(email_text)])
    label = model.predict(vec)[0]
    proba = model.predict_proba(vec)[0]
    return "SPAM" if label == 1 else "HAM", round(max(proba) * 100, 2)

df = pd.read_csv("spam.csv", encoding="latin-1")[["v1", "v2"]]
df.columns = ["label", "text"]
df["text"] = df["text"].apply(clean_text)
df["label_num"] = df["label"].map({"ham": 0, "spam": 1})

X_train, X_test, y_train, y_test = train_test_split(
    df["text"], df["label_num"], test_size=0.2, random_state=42, stratify=df["label_num"]
)
vectorizer = TfidfVectorizer(max_features=3000, stop_words="english")
X_train_tfidf = vectorizer.fit_transform(X_train)
X_test_tfidf  = vectorizer.transform(X_test)

model = MultinomialNB()
model.fit(X_train_tfidf, y_train)
print(classification_report(y_test, model.predict(X_test_tfidf), target_names=["Ham", "Spam"]))

label, confidence = predict(model, vectorizer, "Congratulations! You won a FREE iPhone. Click now!")
print(f"{label} ({confidence}%)")
